venv/

# Data & models (versionados via DVC, não via git)
/data/raw/*
/data/processed/*
/models/*.pt
/models/*.pth
/models/*.joblib
/models/vocab_sizes.json
!/data/raw/.gitkeep
!/data/processed/.gitkeep
!/models/.gitkeep
!/data/raw/*.dvc
!/data/processed/*.dvc
!/models/*.dvc

